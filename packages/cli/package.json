{
  "name": "free-design-md",
  "version": "0.1.3",
  "description": "CLI for browsing and downloading public design.md files from Free design.md",
  "type": "module",
  "bin": {
    "free-design-md": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest --run",
    "prepublishOnly": "corepack pnpm build"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zuchka/free-design-md-catalog.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/zuchka/free-design-md-catalog#readme",
  "bugs": {
    "url": "https://github.com/zuchka/free-design-md-catalog/issues"
  },
  "devDependencies": {
    "@types/node": "^24.2.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "keywords": [
    "design.md",
    "design-tokens",
    "cli"
  ],
  "license": "MIT"
}
